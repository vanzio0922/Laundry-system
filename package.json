{
  "name": "vanzio-laundry",
  "version": "1.0.0",
  "description": "WhatsApp Laundry Bot dengan Cloudflare Workers dan D1",
  "author": "Wira Ananto",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create vanzio-laundry-db",
    "db:migrate": "wrangler d1 execute vanzio-laundry-db --file=schema.sql",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^4.24.3"
  }
}
